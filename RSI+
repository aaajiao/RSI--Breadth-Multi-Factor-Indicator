f_generateSignals(_buyScore, _sellScore, _uptrend, _adjBotTh, _adjStrongBotTh, _adjTopTh, _adjStrongTopTh) =>
    // 买入信号使用买入评分 (含回撤加分)
    strongBot = _buyScore >= _adjStrongBotTh
    bot = _buyScore >= _adjBotTh and _buyScore < _adjStrongBotTh
    // 卖出信号使用卖出评分 (不含回撤加分)
    topCond = _sellScore <= _adjTopTh and _sellScore > _adjStrongTopTh
    strongTopCond = _sellScore <= _adjStrongTopTh
    top = topCond and (not useTrendFilter or not _uptrend)
    strongTop = strongTopCond and (not useTrendFilter or not _uptrend)
    elevated = (topCond or strongTopCond) and _uptrend and useTrendFilter
    [strongBot, bot, top, strongTop, elevated, strongBot or bot, strongTop or top]

