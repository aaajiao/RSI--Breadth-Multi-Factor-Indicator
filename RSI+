        signalLine = signalEmoji + " " + signalText + " " + scoreWithTrend
        table.cell(dashboardMobile, 0, 0, signalLine, bgcolor=signalBgColor, text_color=totalColor, text_size=fontSizeHeader, text_halign=text.align_left)

        // Row 1: Filter Status (过滤状态 - 仅在有过滤时显示)
        table.cell(dashboardMobile, 0, 1, filterStatus, bgcolor=hasFilterStatus ? c_bg_wait : c_bg_row, text_color=filterColor, text_size=fontSize, text_halign=text.align_left)
    else
        //==========================================================
        // v7.3 Full Mode: 7-row × 1-col Compact Dark Theme
        // 单列紧凑设计 + 深色主题 + 无线框
        //==========================================================
        var table dashboard = table.new(dashboardPos, 1, 7, bgcolor=c_bg_row, frame_width=0, border_width=0)
        
        // Row 0: Signal + Score (信号 + 分数)
        scoreStr = str.tostring(displayScore, "+#.#;-#.#") + (displayUptrend ? "↑" : "↓")
        row0 = signalEmoji + " " + signalText + " " + scoreStr
        table.cell(dashboard, 0, 0, row0, bgcolor=signalBgColor, text_color=totalColor, text_size=fontSizeHeader, text_halign=text.align_left)

        // Row 1: Score Progress Bar (分数条)
        scoreBar = f_centeredBar(displayScore, 8.0, 8)
        table.cell(dashboard, 0, 1, scoreBar, bgcolor=signalBgColor, text_color=totalColor, text_size=fontSize, text_halign=text.align_left)

        // Row 2: RSI & Vol (合并)
        rsiColor = displayRsiS > 0 ? color.lime : displayRsiS < 0 ? color.red : color.gray
        rsiBar = f_progressBar(displayRsiS + 2, 0, 4, 4)
        volColor = displayVolS > 0 ? color.lime : displayVolS < 0 ? color.red : color.gray
        volBar = f_progressBar(displayVolS + 2, 0, 4, 4)
        row2 = "RSI" + rsiBar + str.tostring(displayRsiS, "#") + " Vol" + volBar + str.tostring(displayVolS, "#")
        table.cell(dashboard, 0, 2, row2, bgcolor=c_bg_row, text_color=c_text_dim, text_size=fontSize, text_halign=text.align_left)

        // Row 3: FI/ADD & TW (合并)
        twColor = displayTwS > 0 ? color.lime : displayTwS < 0 ? color.red : color.gray
        twBar = f_progressBar(displayTwS + 3, 0, 6, 4)
        string row3 = ""
        if intradayMode
            addBar = f_progressBar(displayAddS + 3, 0, 6, 4)
            row3 := "ADD" + addBar + str.tostring(displayAddS, "#") + " TW" + twBar + str.tostring(displayTwS, "#")
        else
            fiBar = f_progressBar(displayFiS + 3, 0, 6, 4)
            row3 := "FI" + fiBar + str.tostring(displayFiS, "#") + " TW" + twBar + str.tostring(displayTwS, "#")
        table.cell(dashboard, 0, 3, row3, bgcolor=c_bg_row, text_color=c_text_dim, text_size=fontSize, text_halign=text.align_left)

        // Row 4: Trend + Divergence + Quality (趋势+背离+质量)
        trendText = displayUptrend ? "↑UP" : "↓DN"
        trendColor = displayUptrend ? color.lime : color.red
        divText = displayBullishDiv ? "💎B" : displayBearishDiv ? "💎S" : ""
        qualityText = displayBuyQuality + str.tostring(displayPosFactor) + "/4"
        row4 = trendText + " " + divText + " " + qualityText
        table.cell(dashboard, 0, 4, row4, bgcolor=c_bg_row, text_color=trendColor, text_size=fontSize, text_halign=text.align_left)

        // Row 5: DD + Filter Status (回撤+过滤状态)
        ddText = displayDrawdown >= 1 ? "DD" + str.tostring(displayDrawdown, "#") + "%" : ""
        bonusText = displayDrawdownBonus > 0 ? "+" + str.tostring(int(displayDrawdownBonus)) : ""
        row5 = ddText + bonusText + " " + filterStatus
        table.cell(dashboard, 0, 5, row5, bgcolor=c_bg_row, text_color=filterColor, text_size=fontSize, text_halign=text.align_left)

        // Row 6: Three Market Status + Resonance (三市场+共振)
        resonanceIcon = aggBottomEdgeBar ? "🔥" : aggTopEdgeBar ? "❄️" : ""
        row6 = "SPY" + spyStatus + " QQQ" + qqqStatus + " IWM" + iwmStatus + " " + resonanceIcon
        table.cell(dashboard, 0, 6, row6, bgcolor=c_bg_header, text_color=c_text_bright, text_size=fontSize, text_halign=text.align_left)

//========================
// Smart Alert V2 (Enhanced from Adaptive RSI Pro)
// 智能警报：信号等级系统 + K线内去重 + 跨K线防重发 + 升级触发
//========================
grpAlert = "Alerts 警报"
enable_smart_alert = input.bool(true, "Enable Smart Alert 启用智能警报", group=grpAlert, 
    tooltip="V2智能警报：信号等级+升级触发+K线内去重+跨K线防重发\nV2 Smart Alert: signal levels + upgrades + same-bar dedup + cross-bar repeat suppression")
min_alert_level_str = input.string("📈 Lv1 Buy Zone", "Min Alert Level 最小警报等级",
    options=["📈 Lv1 Buy Zone", "💎 Lv2 Divergence", "🔥 Lv3 Resonance", "🚀 Lv4 Panic", "🚀🔥 Lv5 Combo"],
    group=grpAlert, tooltip="Lv1=买入/卖出区间(常见) | Lv2=背离(中等)\nLv3=共振(较少) | Lv4=恐慌/减仓(很少) | Lv5=组合(极少)\n═══════════════════════\nLv1=Buy/Sell zone(common) | Lv2=Divergence(medium)\nLv3=Resonance(rare) | Lv4=Panic/Reduce(very rare) | Lv5=Combo(extreme)")
min_alert_level = min_alert_level_str == "📈 Lv1 Buy Zone" ? 1 : min_alert_level_str == "💎 Lv2 Divergence" ? 2 : min_alert_level_str == "🔥 Lv3 Resonance" ? 3 : min_alert_level_str == "🚀 Lv4 Panic" ? 4 : 5

// 智能提醒直接复用图上绘制所用的 trigger / edge，避免提醒与图形口径漂移
// Smart alerts reuse the same plotted trigger / edge signals to stay aligned with chart markers
autoBotTrig = displayBotTrig
autoStrongBotTrig = displayStrongBotPlotTrig
autoTopTrig = displayTopTrig
autoStrongTopTrig = displayStrongTopPlotTrig
autoBullishDivTrig = showSpy ? spyBullishDivPlotBar : showQqq ? qqqBullishDivPlotBar : showIwm ? iwmBullishDivPlotBar : false
autoBearishDivTrig = showSpy ? spyBearishDivPlotBar : showQqq ? qqqBearishDivPlotBar : showIwm ? iwmBearishDivPlotBar : false
autoElevatedTrig = displayElevatedPlotTrig
autoBotResonanceTrig = showAgg and aggBottomEdgeBar
autoTopResonanceTrig = showAgg and aggTopEdgeBar
alertTickerLabel = showSpy ? "SPY" : showQqq ? "QQQ" : showIwm ? "IWM" : showAgg ? "AGG" : syminfo.ticker

// 信号等级函数 (优先级越高值越大)
// 5=恐慌+共振 | 4=恐慌低点 | 3=共振 | 2=背离 | 1=低吸/观望
f_buy_level(_strongBot, _bot, _resonance, _div) =>
    // 仅在当前显示路径已有主买入触发时才允许 Lv2/Lv3 升级，避免“只提醒不落图”
    // Only allow Lv2/Lv3 upgrades when a visible base buy trigger exists on the current display path.
    hasBaseBuy = _strongBot or _bot
    if not hasBaseBuy
        0
    else
        _strongBot and _resonance ? 5 : _strongBot ? 4 : _resonance ? 3 : _div ? 2 : 1

f_sell_level(_strongTop, _top, _resonance, _div, _elevated) =>
    // 仅在当前显示路径已有主风险触发时才允许 Lv2/Lv3 升级，避免“只提醒不落图”
    // Only allow Lv2/Lv3 upgrades when a visible base risk trigger exists on the current display path.
    hasBaseSell = _strongTop or _top or _elevated
    if not hasBaseSell
        0
    else
        _strongTop and _resonance ? 5 : _strongTop ? 4 : _resonance ? 3 : _div ? 2 : 1

// varip: 在实时K线的多次重算间保留状态，避免 rollback 导致同级别警报重复触发
varip int buy_alert_level_sent = 0
varip int sell_alert_level_sent = 0
varip int buy_alert_level_published = 0
varip int sell_alert_level_published = 0
varip bool buy_alert_armed = true
varip bool sell_alert_armed = true
varip int buy_alert_latched_level = 0
varip int sell_alert_latched_level = 0
varip bool smart_alert_fired_this_bar = false

// 新K线开始时重置
if barstate.isnew
    buy_alert_level_sent := 0
    sell_alert_level_sent := 0
    smart_alert_fired_this_bar := false

current_buy_level = f_buy_level(autoStrongBotTrig, autoBotTrig, autoBotResonanceTrig, autoBullishDivTrig)
current_sell_level = f_sell_level(autoStrongTopTrig, autoTopTrig, autoTopResonanceTrig, autoBearishDivTrig, autoElevatedTrig)
buy_signal_active = current_buy_level > 0
sell_signal_active = current_sell_level > 0
regular_session_alerts = not intradayMode or session.ismarket
live_intraday_latch_mode = intradayMode and useLiveData
prev_regular_session = bar_index > 0 ? session.ismarket[1] : false
new_live_intraday_session = live_intraday_latch_mode and session.ismarket and not prev_regular_session
prev_buy_side_active = bar_index > 0 ? alertBuySideActive[1] : false
prev_sell_side_active = bar_index > 0 ? alertSellSideActive[1] : false

if not live_intraday_latch_mode
    buy_alert_armed := true
    sell_alert_armed := true
    buy_alert_latched_level := 0
    sell_alert_latched_level := 0
    if barstate.isnew and not prev_buy_side_active
        buy_alert_level_published := 0
    if barstate.isnew and not prev_sell_side_active
        sell_alert_level_published := 0
else if new_live_intraday_session
    buy_alert_armed := true
    sell_alert_armed := true
    buy_alert_latched_level := 0
    sell_alert_latched_level := 0

// 日内智能警报仅在常规交易时段触发，避免盘后 1 分钟图用冻结广度反复提醒
// Intraday smart alerts only fire during regular market hours to avoid repeated after-hours alerts on frozen breadth data
if enable_smart_alert and regular_session_alerts
    // === 买入信号 ===
    // 触发条件：首次发布 / 跨K线升级；同一根K线只允许发布一次，避免重复提醒
    // Trigger: first publish / cross-bar upgrade; allow only one smart alert per bar to prevent repeats.
    should_alert_buy_base = buy_signal_active and current_buy_level >= min_alert_level and current_buy_level > buy_alert_level_sent and (live_intraday_latch_mode ? (buy_alert_armed or current_buy_level > buy_alert_latched_level) : current_buy_level > buy_alert_level_published)
    should_alert_sell_base = sell_signal_active and current_sell_level >= min_alert_level and current_sell_level > sell_alert_level_sent and (live_intraday_latch_mode ? (sell_alert_armed or current_sell_level > sell_alert_latched_level) : current_sell_level > sell_alert_level_published)

    should_alert_buy = should_alert_buy_base
    should_alert_sell = should_alert_sell_base

    // 若买卖同tick都满足，只发布等级更高的一侧
    // If both sides qualify on the same tick, publish only the higher-level side.
    if should_alert_buy_base and should_alert_sell_base
        if current_sell_level > current_buy_level
            should_alert_buy := false
        else
            should_alert_sell := false

    if not smart_alert_fired_this_bar
        if should_alert_buy
            msg = str.format("{0}: 🟢 BUY Lv{1} → ", alertTickerLabel, current_buy_level)

            // Signal labels (combo priority)
            if autoStrongBotTrig and autoBotResonanceTrig
                msg := msg + "🚀Panic+🔥Resonance "
            else if autoStrongBotTrig
                msg := msg + "🚀Panic Low "
            else if autoBotResonanceTrig
                msg := msg + "🔥Resonance "
            else if autoBotTrig
                msg := msg + "📈Buy Zone "
            if autoBullishDivTrig
                msg := msg + "💎Divergence "

            // v7.0 Context info (quality + drawdown + score)
            trend_ctx = displayUptrend ? "↑UP" : "↓DOWN"
            dd_ctx = displayDrawdown >= 5 ? str.format(" DD:{0,number,#}%", displayDrawdown) : ""
            msg := msg + str.format("| Score:{0,number,#.1} ({1}){2} {3}",
                displayScore, displayBuyQuality, dd_ctx, trend_ctx)

            alert(msg, alert.freq_all)
            smart_alert_fired_this_bar := true
            buy_alert_level_sent := current_buy_level
            if live_intraday_latch_mode
                buy_alert_armed := false
                buy_alert_latched_level := current_buy_level
            else
                buy_alert_level_published := current_buy_level
        else if should_alert_sell
            msg = str.format("{0}: 🔴 RISK Lv{1} → ", alertTickerLabel, current_sell_level)

            // Signal labels (combo priority)
            if autoStrongTopTrig and autoTopResonanceTrig
                msg := msg + "⚠️Reduce+❄️Resonance "
            else if autoStrongTopTrig
                msg := msg + "⚠️Reduce "
            else if autoTopResonanceTrig
                msg := msg + "❄️Resonance "
            else if autoTopTrig
                msg := msg + "⚡Caution "
            else if autoElevatedTrig
                msg := msg + "⭐Elevated "
            if autoBearishDivTrig
                msg := msg + "💎Divergence "

            // v7.0 Context info (score + trend)
            trend_ctx = displayUptrend ? "↑UP" : "↓DOWN"
            msg := msg + str.format("| Score:{0,number,#.1} {1}", displayScore, trend_ctx)

            alert(msg, alert.freq_all)
            smart_alert_fired_this_bar := true
            sell_alert_level_sent := current_sell_level
            if live_intraday_latch_mode
                sell_alert_armed := false
                sell_alert_latched_level := current_sell_level
            else
                sell_alert_level_published := current_sell_level
