// v7.2: Progress Bar Generator (进度条生成器)
// 生成可视化进度条字符串
f_progressBar(_value, _min, _max, _length) =>
    normalized = math.max(0.0, math.min(1.0, (_value - _min) / (_max - _min)))
    filled = int(math.round(normalized * _length))
    empty = _length - filled
    result = ""
    if filled > 0
        for i = 0 to filled - 1
            result := result + "█"
    if empty > 0
        for i = 0 to empty - 1
            result := result + "░"
    result

// v7.2: Centered Progress Bar (居中进度条 - 用于分数显示)
// 中点为0，负值向左填充，正值向右填充
f_centeredBar(_value, _absMax, _halfLength) =>
    // _halfLength 是单侧长度，总长度为 _halfLength * 2
    leftPart = ""
    rightPart = ""
    if _value >= 0
        // 正值：左边全空，右边填充
        leftFilled = 0
        rightFilled = int(math.round(math.min(_value, _absMax) / _absMax * _halfLength))
        for i = 0 to _halfLength - 1
            leftPart := leftPart + "░"
        for i = 0 to _halfLength - 1
            rightPart := rightPart + (i < rightFilled ? "█" : "░")
    else
        // 负值：左边从右向左填充，右边全空
        leftFilled = int(math.round(math.min(math.abs(_value), _absMax) / _absMax * _halfLength))
        for i = 0 to _halfLength - 1
            leftPart := leftPart + (i >= _halfLength - leftFilled ? "█" : "░")
        for i = 0 to _halfLength - 1
            rightPart := rightPart + "░"
    leftPart + "│" + rightPart

// v7.2: Market Status Indicator (市场状态指示器)
f_marketStatus(_score, _botTh, _topTh) =>
    _score >= _botTh ? "🟢" : _score <= _topTh ? "🔴" : "🟡"

// 日内请求继承图表 session，避免 regular 数据被盘后 K 线错误延展
// Intraday requests inherit the chart session to avoid synthetic post-market carry-forward
f_intradayTicker(_sym) =>
    intradayMode ? ticker.modify(_sym, syminfo.session) : _sym

f_sec(_sym, _expr) =>
    reqSym = f_intradayTicker(_sym)
    reqGaps = intradayMode ? barmerge.gaps_on : barmerge.gaps_off
    request.security(reqSym, tfData, _expr, reqGaps, barmerge.lookahead_off)

f_ohlc(_sym) =>
    reqSym = f_intradayTicker(_sym)
    reqGaps = intradayMode ? barmerge.gaps_on : barmerge.gaps_off
    request.security(reqSym, tfData, [open, high, low, close], reqGaps, barmerge.lookahead_off)

// 已确认日线：返回上一根确认完成的日线值，避免实时 HTF 漂移
// Confirmed daily: use the last fully confirmed daily bar
f_secDaily(_sym, _expr) =>
    request.security(_sym, "D", _expr[1], barmerge.gaps_off, barmerge.lookahead_on)

// 日内图获取当日developing数据 (lookahead_on使盘中可用，日线图不需要)
// Intraday: get developing daily data (lookahead_on for timely alerts)
f_secDailyLive(_sym, _expr) =>
    request.security(_sym, "D", _expr, barmerge.gaps_off, barmerge.lookahead_on)

f_rsi_from_close(_c) =>
