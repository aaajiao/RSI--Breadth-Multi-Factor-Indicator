f_recent(_cond, _bars) =>
    if _bars == 0
        _cond
    else
        bs = ta.barssince(_cond)
        not na(bs) and bs <= _bars

f_applyCooldown(_rawSig, _coolBars, _lastBar) =>
    can = na(_lastBar) or (bar_index - _lastBar >= _coolBars)
    _rawSig and (_coolBars == 0 or can)

// Dynamic Cooldown Function (动态冷却计算)
// High volatility → shorter cooldown (market moves fast, need quick response)
// Low volatility → longer cooldown (market calm, avoid noise signals)
f_dynamicCooldown(_baseCooldown, _volFast, _volThreshold) =>
    if _baseCooldown == 0
        0  // 保留用户 "无限制" 设定 Preserve user's "no limit" setting
    else
        volRatio = _volFast / _volThreshold
        // 高波动 (>1.2x): 60% 冷却 | 正常: 100% | 低波动 (<0.8x): 150% 冷却
        adjustedCooldown = volRatio > 1.2 ? int(_baseCooldown * 0.6) : volRatio < 0.8 ? int(_baseCooldown * 1.5) : _baseCooldown
        math.max(3, adjustedCooldown)  // 最小3根K线

